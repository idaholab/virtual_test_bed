[GENERAL]
polynomialOrder = 7
#startFrom = 
stopAt = numSteps
numSteps = 10000

timeStepper = tombo1
#dt = 1.0e-6
#subCyclingSteps = 2
dt = targetCFL=4 + max=1e-2 + initial=1e-6

checkpointControl = steps
checkpointInterval = 1000

regularization = hpfrt + nModes=1 + scalingCoeff=20

[PRESSURE]
residualTol = 1e-04
initialGuess = projectionAconj+nVector=10

[VELOCITY]
boundaryTypeMap = W
rho = 1.0
viscosity = 1/10742.82
residualTol = 1e-06

[TEMPERATURE]
solver = none
