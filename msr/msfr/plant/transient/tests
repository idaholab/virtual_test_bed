[Tests]
  # Syntax checks
  [coupled_multiphysics_syntax]
    type = RunApp
    input = 'run_neutronics.i'
    check_input = True
    # PTFunctionEOS warning: A user input enthalpy function is provided. Suggest providing valid temperature range to calculate enthalpy internally based on Cp.
    allow_warnings = True
    # See Griffin #2020
    capabilities = 'method=opt & (bluecrabapp | salamanderapp)'
  []
  [neutronics_only_syntax]
    type = RunApp
    input = 'run_neutronics.i'
    check_input = True
    cli_args = "MultiApps/active='' Transfers/active=''"
    # Cross section chi spectrum does not sum to 1
    allow_warnings = true
    # See Griffin #2020
    capabilities = 'method=opt & (griffinapp | bluecrabapp | direwolfapp | salamanderapp)'
  []
  [core_fluids_syntax]
    type = RunApp
    input = 'run_ns.i'
    check_input = True
    cli_args = "MultiApps/active='' Transfers/active=''"
    capabilities = 'combinedapp | bluecrabapp | direwolfapp | pronghornapp | salamanderapp'
  []
  [plant_syntax]
    type = RunApp
    input = 'msfr_system_1d.i'
    check_input = True
    # PTFunctionEOS warning: A user input enthalpy function is provided. Suggest providing valid temperature range to calculate enthalpy internally based on Cp.
    allow_warnings = True
    capabilities = 'samapp | bluecrabapp'
    cli_args = "--app SamApp"
  []
[]
