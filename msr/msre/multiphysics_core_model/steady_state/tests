[Tests]
  # Syntax checks
  [generate_mesh]
    type = RunApp
    capabilities = 'griffinapp | pronghornapp'
    input = '../mesh/mesh.i'
    cli_args = '--mesh-only'
    working_directory = '../mesh'
  []
  [neu_msre_syntax]
    type = RunApp
    input = 'neu.i'
    check_input = True
    capabilities = 'griffinapp'
    cli_args = "MultiApps/active='' Transfers/active=''"
    prereq = generate_mesh
  []
  [th_msre_syntax]
    type = RunApp
    input = 'th.i'
    check_input = True
    # TODO: remove this one https://github.com/idaholab/moose/pull/27614 is merged
    capabilities = 'method=opt & pronghornapp'
  []
  # Regression tests with CSV output over a minimum amount of time steps/computation
  [neu_msre]
    prereq = neu_msre_syntax
    type = CSVDiff
    rel_err = 1.0E-4
    input = 'neu.i'
    csvdiff = 'msre_neutronics_ss_s2_out.csv'
    allow_warnings = true
    cli_args = "MultiApps/active='' Transfers/active=''"
    capabilities = 'method=opt & griffinapp'
  []
  [th_msre]
    prereq = th_msre_syntax
    type = CSVDiff
    rel_err = 1.0E-4
    input = 'th.i'
    csvdiff = 'th_out.csv'
    allow_warnings = true
    capabilities = 'method=opt & pronghornapp'
    min_parallel = 8
  []
[]
