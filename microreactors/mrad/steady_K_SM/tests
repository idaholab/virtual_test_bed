[Tests]
  # Steady
  # Syntax checks
  [neutronics_griffin_syntax]
    type = RunApp
    input = 'K-HPMR_GRIFFIN.i'
    check_input = True
    executable_pattern = 'griffin*|blue_crab*|dire_wolf*'
    cli_args = "MultiApps/active='' Transfers/active=''"
  []
  [thermomechanics_bison_syntax]
    type = RunApp
    input = 'K-HPMR_BISON.i'
    check_input = True
    executable_pattern = 'bison*|blue_crab*|dire_wolf*'
    cli_args = "MultiApps/active='' Transfers/active=''"
  []
  [fluids_sockeye_syntax]
    type = RunApp
    input = 'K-HPMR_SOCKEYE.i'
    check_input = True
    executable_pattern = 'sockeye*|dire_wolf*'
    allow_warnings = true
  []

  # Regression tests
  # BISON standalone and coupled simulation regression tests done in hpc_tests due to large mesh for solid mechanics solve.
  [neutronics_griffin]
    type = CSVDiff
    input = 'K-HPMR_GRIFFIN.i'
    csvdiff = 'K-HPMR_GRIFFIN_out.csv'
    executable_pattern = 'griffin*|blue_crab*|dire_wolf*'
    # Setup outputs, reduce costs
    cli_args = "MultiApps/active='' Transfers/active=''
                Outputs/csv=true Outputs/exodus=false
                --distributed-mesh TransportSystems/sn/order=CONSTANT Executioner/richardson_max_its=1"
    min_parallel = 16
    capabilities = 'method=opt'
    max_time = 400
    # Cross-section warning due to missing fission-only
    allow_warnings = true
    prereq = 'neutronics_griffin_syntax'
  []
  [fluids_sockeye]
    type = CSVDiff
    input = 'K-HPMR_SOCKEYE.i'
    csvdiff = 'K-HPMR_SOCKEYE_out.csv'
    abs_zero = 1e-9
    executable_pattern = 'sockeye*|dire_wolf*'
    cli_args = "Outputs/csv/enable=true"
    allow_warnings = true
    prereq = 'fluids_sockeye_syntax'
  []

  # Load following
  # Syntax checks
  [neutronics_griffin_syntax_load]
    type = RunApp
    working_directory = '../load_following_K_SM'
    input = 'K-HPMR_GRIFFIN_tr.i'
    check_input = True
    executable_pattern = 'griffin*|blue_crab*|dire_wolf*'
    cli_args = "MultiApps/active='' Transfers/active=''"
    prereq = 'neutronics_griffin'
    # restart file was created in parallel
    min_parallel = 16
    # Cross-section warning due to missing fission-only
    allow_warnings = true
  []
  [fluids_sockeye_syntax_load]
    type = RunApp
    working_directory = '../load_following_K_SM'
    input = 'K-HPMR_SOCKEYE_tr.i'
    check_input = True
    # Needs some initialization
    cli_args = 'Components/hp/initial_T=800'
    executable_pattern = 'sockeye*|dire_wolf*'
    # Capillary limit for vertical heat pipes is not accurate; see https://hpcgitlab.hpc.inl.gov/idaholab/sockeye/-/issues/65
    allow_warnings = true
    prereq = 'fluids_sockeye'
  []
[]
