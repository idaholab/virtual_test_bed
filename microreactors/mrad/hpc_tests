  [thermomechanics_bison]
    type = CSVDiff
    working_directory = 'steady_K_SM'
    input = 'K-HPMR_BISON.i'
    csvdiff = 'K-HPMR_BISON_out.csv'
    executable_pattern = 'bison*|blue_crab*|dire_wolf*'
    cli_args = "MultiApps/active='' Transfers/active='' Executioner/num_steps=2 "
               "Executioner/nl_abs_tol=1e-1 Outputs/csv=true --distributed-mesh Outputs/exodus=false"
    min_parallel = 96
    capabilities = 'method=opt'
    abs_zero = 1e-7
    rel_err = 1e-6
    max_time = 1000
  []

  [thermomechanics_bison_syntax_load]
    type = RunApp
    working_directory = 'load_following_K_SM'
    input = 'K-HPMR_BISON_tr.i'
    check_input = True
    executable_pattern = 'bison*|blue_crab*|dire_wolf*'
    cli_args = "MultiApps/active='' Transfers/active=''
                Problem/restart_file_base='../steady_K_SM/K-HPMR_BISON_out_cp/LATEST'
                Mesh/file='../steady_K_SM/K-HPMR_BISON_out_cp/LATEST'
                --distributed-mesh"
    prereq = 'thermomechanics_bison'
    # restart file was created in parallel
    min_parallel = 96
    abs_zero = 1e-7
    rel_err = 1e-6
  []

