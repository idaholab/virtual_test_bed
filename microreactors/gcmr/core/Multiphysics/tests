[Tests]
  # Multiphysics Full Core Models
  # griffin mesh needs to be generated by the single-physics test
  [generate_griffin_mesh]
    type = RunApp
    input = 'Griffin_mesh.i'
    cli_args = '--mesh-only'
    executable_pattern = 'griffin*|blue_crab*'
    working_directory = 'mesh'
  []
  [generate_bison_mesh]
    type = RunApp
    input = 'BISON_mesh.i'
    cli_args = '--mesh-only'
    executable_pattern = 'griffin*|blue_crab*'
    working_directory = 'mesh'
    prereq = 'generate_griffin_mesh'
  []
  [MP_Griffin_syntax]
    type = RunApp
    check_input = true
    input = 'MP_Griffin_ss.i'
    cli_args = "MultiApps/active='' Transfers/active=''"
    executable_pattern = 'griffin*|blue_crab*'
    capabilities = 'method=opt'
    max_time = 600
    # Griffin does not have the sam petsc option parameter
    allow_unused = true
    working_directory = 'steady_state'
    prereq = 'generate_griffin_mesh'
  []
  [MP_BISON_syntax]
    type = RunApp
    check_input = true
    input = 'MP_BISON_ss.i'
    cli_args = "MultiApps/active='' Transfers/active=''"
    executable_pattern = 'bison*|blue_crab*'
    capabilities = 'method=opt'
    max_time = 600
    working_directory = 'steady_state'
    prereq = 'generate_bison_mesh'
  []
  [MP_SAM_syntax]
    type = RunApp
    check_input = true
    input = 'MP_SAM_ss.i'
    cli_args = "--app ThermalHydraulicsApp"
    executable_pattern = 'sam*|blue_crab*'
    capabilities = 'method=opt'
    max_time = 600
    working_directory = 'steady_state'
  []
  [MP_Griffin_FP_syntax]
    type = RunApp
    check_input = true
    input = 'MP_Griffin_ss_fp.i'
    cli_args = "MultiApps/active='' Transfers/active=''"
    executable_pattern = 'griffin*|blue_crab*'
    capabilities = 'method=opt'
    max_time = 600
    # Griffin does not have the sam petsc option parameter
    allow_unused = true
    working_directory = 'steady_state_fp'
    prereq = 'generate_griffin_mesh'
  []
  [MP_BISON_FP_syntax]
    type = RunApp
    check_input = true
    input = 'MP_BISON_ss_fp.i'
    cli_args = "MultiApps/active='' Transfers/active=''"
    executable_pattern = 'bison*|blue_crab*'
    capabilities = 'method=opt'
    max_time = 600
    working_directory = 'steady_state_fp'
    prereq = 'generate_bison_mesh'
  []
  [MP_SAM_FP_syntax]
    type = RunApp
    check_input = true
    input = 'MP_SAM_ss_fp.i'
    cli_args = "--app ThermalHydraulicsApp"
    executable_pattern = 'sam*|blue_crab*'
    capabilities = 'method=opt'
    max_time = 600
    working_directory = 'steady_state_fp'
  []

  [MP_SAM_scb_syntax]
    type = RunApp
    check_input = true
    input = 'MP_SAM_scb.i'
    cli_args = "--app ThermalHydraulicsApp
                GlobalParams/initial_p=${Pout}
                GlobalParams/initial_vel=${Vin}
                GlobalParams/initial_T=${Tin}"
    executable_pattern = 'sam*|blue_crab*'
    capabilities = 'method=opt'
    max_time = 600
    working_directory = 'single_channel_blockage'
  []
  [MP_SAM_dp_syntax]
    type = RunApp
    check_input = true
    input = 'MP_SAM_dp.i'
    cli_args = "--app ThermalHydraulicsApp
                GlobalParams/initial_p=${Pout}
                GlobalParams/initial_vel=${Vin}
                GlobalParams/initial_T=${Tin}"
    executable_pattern = 'sam*|blue_crab*'
    capabilities = 'method=opt'
    max_time = 600
    working_directory = 'depressurization'
  []
  [MP_SAM_fp_syntax]
    type = RunApp
    check_input = true
    input = 'MP_SAM_tr_fp.i'
    cli_args = "--app ThermalHydraulicsApp
                GlobalParams/initial_p=${Pout}
                GlobalParams/initial_vel=${Vin}
                GlobalParams/initial_T=${Tin}"
    executable_pattern = 'sam*|blue_crab*'
    capabilities = 'method=opt'
    max_time = 600
    working_directory = 'transient_fp'
  []
[]
