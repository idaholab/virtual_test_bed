[Tests]
  # Generate the meshes
  [neutronics_coarse_mesh]
    type = CheckFiles
    input = one_twelfth_simba_core_CM.i
    cli_args = '--mesh-only'
    capabilities = 'griffinapp | bluecrabapp | direwolfapp'
    check_files = one_twelfth_simba_core_CM_in.e
  []
  [neutronics_fine_mesh]
    type = CheckFiles
    input = one_twelfth_simba_core.i
    cli_args = '--mesh-only'
    check_files = one_twelfth_simba_core_in.e
    capabilities = 'griffinapp | bluecrabapp | direwolfapp'
    prereq = neutronics_coarse_mesh
  []

  [thermal_only]
    type = CSVDiff
    input = 'thermal_ss.i'
    csvdiff = 'thermal_ss_out.csv'
    capabilities = 'bluecrabapp | direwolfapp'
    cli_args = "MultiApps/active='' Transfers/active=''"
    min_parallel = 192
    # Observed variability on H postprocessing
    rel_err = 1e-5
  []

  [griffin_only]
    type = CSVDiff
    input = 'neutronics_eigenvalue.i'
    csvdiff = 'neutronics_eigenvalue_standalone.csv'
    capabilities = 'griffinapp | bluecrabapp | direwolfapp'
    cli_args = "MultiApps/active='' Transfers/active='' AuxVariables/Trefl/initial_condition=800 "
               "Outputs/file_base=neutronics_eigenvalue_standalone"
    min_parallel = 192
    prereq = neutronics_fine_mesh
  []

  [coupled_run]
    type = CSVDiff
    csvdiff = 'neutronics_eigenvalue.csv'
    # file base is coded into the input
    input = 'neutronics_eigenvalue.i'
    capabilities = 'direwolfapp'
    min_parallel = 192
    prereq = griffin_only
    # Timed out at 600s
    # Timed out again at 1500s
    max_time = 2000
    # Observed variability on HPC runs
    rel_err = 7e-5
  []
[]
