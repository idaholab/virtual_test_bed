  # Regression tests
  [step1]
    type = CSVDiff
    input = step1.i
    csvdiff = step1_out.csv
    cli_args = 'Outputs/csv=true'
    capabilities = 'pronghornapp | bluecrabapp'
  []
  [step2]
    type = CSVDiff
    input = step2.i
    csvdiff = step2_out.csv
    # preserve the original time steps
    cli_args = "Outputs/csv=true
                Executioner/TimeStepper/type=CSVTimeSequenceStepper
                Executioner/TimeStepper/file_name=gold/step2_out.csv
                Executioner/TimeStepper/column_name=time"
    allow_unused = true
    capabilities = 'pronghornapp | bluecrabapp'
  []
  [step3]
    type = CSVDiff
    input = step3.i
    csvdiff = step3_out.csv
    cli_args = 'Outputs/csv=true'
    capabilities = 'pronghornapp | bluecrabapp'
  []
  [step4]
    type = CSVDiff
    input = step4.i
    csvdiff = step4_out.csv
    cli_args = 'Outputs/csv=true'
    capabilities = 'pronghornapp | bluecrabapp'
  []
  [step5]
    type = CSVDiff
    input = step5.i
    csvdiff = step5_out.csv
    cli_args = 'Outputs/csv=true'
    capabilities = 'pronghornapp | bluecrabapp'
    # Relaxing due to switch from MUMPS to SUPERLU_dist
    abs_zero = 3e-5
    rel_err = 3e-5
  []
  [step6]
    type = CSVDiff
    input = step6.i
    csvdiff = step6_out.csv
    # preserve the original time steps
    cli_args = "Outputs/csv=true
                Executioner/TimeStepper/type=CSVTimeSequenceStepper
                Executioner/TimeStepper/file_name=gold/step6_out.csv
                Executioner/TimeStepper/column_name=time"
    allow_unused = true
    rel_err = 5e-5
    capabilities = 'pronghornapp | bluecrabapp'
  []
  [step7]
    type = CSVDiff
    input = step7.i
    csvdiff = step7_out.csv
    cli_args = 'Outputs/csv=true'
    capabilities = 'pronghornapp | bluecrabapp'
  []
  [step8]
    type = CSVDiff
    input = step8.i
    csvdiff = step8_out.csv
    cli_args = 'Outputs/csv=true'
    capabilities = 'pronghornapp | bluecrabapp'
  []
